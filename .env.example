# =========================
# 기본 실행 모드
# =========================
SINGLE_BOT_MODE=true
USE_MOCK_GEMINI=true

# Make.com은 기본 비활성화.
# false면 버튼 클릭 시 디스코드에 payload preview만 출력합니다.
ENABLE_MAKE_WEBHOOK=false
MAKE_WEBHOOK_URL=

# =========================
# Gemini
# =========================
GOOGLE_API_KEY=

# =========================
# Discord Bot Tokens
# SINGLE_BOT_MODE=true 상태에서는 TOKEN_DIRECTOR만 있어도 테스트 가능
# =========================
TOKEN_DIRECTOR=

TOKEN_ANALYST_HEALTH=
TOKEN_ANALYST_FOOD=
TOKEN_ANALYST_LIVING=

TOKEN_CREATIVE_INSTAGRAM=
TOKEN_CREATIVE_THREADS=
TOKEN_CREATIVE_BLOG=
TOKEN_CREATIVE_VISUAL=

TOKEN_MARKETER_TAG=
TOKEN_MARKETER_TIKTOK=
TOKEN_MARKETER_STRATEGY=
